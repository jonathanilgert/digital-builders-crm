# Required for app login (UI). Generate: `openssl rand -hex 32`
# Rotating this invalidates all existing browser sessions.
JWT_SECRET=

# Required for app login. Shared password — both you and Alex use this.
APP_PASSWORD=

# Required for /api/integrations/* endpoints (OpenClaw / cron jobs).
# Generate a long random string: `openssl rand -hex 32`
OPENCLAW_API_KEY=

# Optional - server port (defaults to 3001)
PORT=3001
